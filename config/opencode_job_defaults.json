{
  "schema_version": 1,
  "jobs_dir": "_local/codex-token-monitor/opencode-jobs",
  "timeout_seconds": 600,
  "poll_interval_ms": 1000,
  "provider_id": "opencode",
  "model_id": "deepseek-v4-flash-free",
  "opencode_command": "",
  "debug_visible_terminal": false,
  "debug_open_session_tui": false,
  "opencode_attach_url": "",
  "export_session": "on_failure",
  "summary_tail_lines": 80,
  "summary_max_chars": 4000,
  "cleanup_success_after_days": 7,
  "cleanup_failure_after_days": 30,
  "cleanup_keep_recent": 20,
  "command_template": [
    "python",
    "scripts/codex_token_monitor_opencode_adapter.py",
    "--task-file", "{task_file}",
    "--job-dir", "{job_dir}",
    "--provider-id", "{provider_id}",
    "--model-id", "{model_id}"
  ]
}
